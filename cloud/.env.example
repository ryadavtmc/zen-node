# =============================================================================
# ZenNode Cloud API — Environment Variables
# Copy to .env and fill in your values.
# =============================================================================

# Database — SQLite for dev, PostgreSQL for production
DATABASE_URL=sqlite:///./zennode_cloud.db
# DATABASE_URL=postgresql://zennode:password@localhost:5432/zennode_cloud

# JWT — CHANGE THIS in production (use: openssl rand -hex 32)
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_EXPIRE_MINUTES=10080

# Server
API_PORT=8421
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
