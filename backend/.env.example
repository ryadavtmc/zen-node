# =============================================================================
# ZenNode Backend — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# LLM Configuration (used only when ZenNode enters "Red Zone" — score > 80)
# Supports any OpenAI-compatible API (OpenAI, Ollama, Together, Groq, etc.)

# Your LLM API key
LLM_API_KEY=your_api_key_here

# The model to use (e.g. llama-3.3-70b-versatile, gpt-4o-mini, mixtral, etc.)
LLM_MODEL=llama-3.3-70b-versatile

# Base URL for the LLM API (change for different providers)
# Groq:    https://api.groq.com/openai/v1
# OpenAI:  https://api.openai.com/v1
# Ollama:  http://localhost:11434/v1
LLM_BASE_URL=https://api.groq.com/openai/v1

# Enable/disable LLM calls (set to false to run without any LLM)
LLM_ENABLED=true
